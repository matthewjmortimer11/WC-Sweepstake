# Copy to .env in the project root (or export in your shell) for MCP servers.
# Never commit .env — it is gitignored.

# GitHub MCP — fine-grained PAT with repo/issues/PR read (and write if you want agent PRs)
GITHUB_TOKEN=

# Context7 — optional but recommended for higher rate limits (https://context7.com)
CONTEXT7_API_KEY=

# Postgres MCP — read-only dev/staging URL (postgresql:// not postgresql+asyncpg://)
# Example: postgresql://readonly:secret@localhost:5432/wheesht
WHEESHT_POSTGRES_MCP_URL=

# Firecrawl — https://firecrawl.dev
FIRECRAWL_API_KEY=

# Stripe MCP (local stdio mode only — remote https://mcp.stripe.com uses OAuth in Cursor)
# Prefer a restricted test key (rk_test_…) if using local mode:
# STRIPE_SECRET_KEY=

# Railway CLI auth is via `railway login` — no env var needed for railway mcp
